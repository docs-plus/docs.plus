GRAFANA_ADMIN_PASSWORD=changeme-local
GLITCHTIP_SECRET_KEY=changeme-local
GLITCHTIP_POSTGRES_PASSWORD=changeme-local
TELEGRAM_BOT_TOKEN=changeme-local
TELEGRAM_CHAT_ID=changeme-local
DATABASE_URL=changeme-local
# healthchecks.io ping URL — the deadman snitch pages when these pings STOP (required,
# non-empty: an empty value renders an empty webhook and breaks Grafana provisioning).
DEADMAN_WEBHOOK_URL=https://hc-ping.com/changeme-local
# Optional: separate chat for warning-severity alerts; defaults to TELEGRAM_CHAT_ID.
TELEGRAM_WARNINGS_CHAT_ID=
# Optional: Django-style SMTP URL for GlitchTip issue emails; empty = console backend.
GLITCHTIP_EMAIL_URL=
