          "expr": "100 * sum(rate(traefik_service_requests_total{service=~\"hocuspocus.*|rest-api.*\",code=~\"5..|0\"}[5m])) / clamp_min(sum(rate(traefik_service_requests_total{service=~\"hocuspocus.*|rest-api.*\"}[5m])), 1)",
          "refId": "A",
          "legendFormat": "Error %"
