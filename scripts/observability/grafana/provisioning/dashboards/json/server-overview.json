{
  "uid": "docsplus-server-overview",
  "title": "docs.plus — Server Overview",
  "schemaVersion": 39,
  "editable": true,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "tags": ["docs.plus", "infra"],
  "timezone": "browser",
  "id": null,
