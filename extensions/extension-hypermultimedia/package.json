{
  "name": "@docs.plus/extension-hypermultimedia",
  "version": "2.0.0",
  "description": "Tiptap extension for embedded multimedia: images, audio, video, YouTube, Vimeo, SoundCloud, Loom, and X — with resize, captions, and a media toolbar",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "author": "Hossein Marzban",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=24.11.0"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "homepage": "https://github.com/docs-plus/docs.plus/tree/main/extensions/extension-hypermultimedia#readme",
  "bugs": {
    "url": "https://github.com/docs-plus/docs.plus/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/docs-plus/docs.plus",
    "directory": "extensions/extension-hypermultimedia"
  },
  "scripts": {
    "build": "NODE_ENV=production bunx tsup",
    "dev": "bunx tsup --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "playground": "bun --hot docs-playground --entry ./test/playground/main.ts --port 5174 --readme-media-dir ./assets/readme-media",
    "docs:screenshots": "bun run --filter @docs.plus/extension-hyperlink build && bun run build && bunx start-server-and-test playground http://127.0.0.1:5174 'bunx cypress run --config specPattern=cypress/docs/**/*.cy.ts'",
    "pretest": "bun run build",
    "test": "bunx start-server-and-test playground http://127.0.0.1:5174 cypress:run",
    "test:e2e": "bunx start-server-and-test playground http://127.0.0.1:5174 cypress:run",
    "test:e2e:watch": "bunx start-server-and-test playground http://127.0.0.1:5174 cypress:open",
    "cypress:run": "bunx cypress run",
    "cypress:open": "bunx cypress open",
    "prepack": "bunx release-prepack",
    "prepublishOnly": "bunx release-preflight"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "tiptap",
    "tiptap extension",
    "embed",
    "multimedia",
    "floating-ui",
    "image",
    "video",
    "audio",
    "loom",
    "youtube",
    "vimeo",
    "soundcloud",
    "x",
    "prosemirror",
    "docs.plus"
  ],
  "peerDependencies": {
    "@tiptap/core": "catalog:",
    "@tiptap/pm": "catalog:"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6"
  },
  "devDependencies": {
    "@docs.plus/extension-hyperlink": "workspace:*",
    "@docs.plus/floating-popover": "workspace:*",
    "@docs.plus/floating-tooltip": "workspace:*",
    "@docs.plus/playground": "workspace:*",
    "@docs.plus/release-tooling": "workspace:*",
    "@tiptap/core": "catalog:",
    "@tiptap/markdown": "catalog:",
    "@tiptap/pm": "catalog:",
    "@tiptap/starter-kit": "catalog:",
    "@eslint/js": "catalog:",
    "@types/minimatch": "catalog:",
    "@typescript-eslint/eslint-plugin": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "bun-types": "catalog:",
    "cypress": "catalog:",
    "cypress-real-events": "catalog:",
    "eslint": "catalog:",
    "globals": "catalog:",
    "start-server-and-test": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:"
  }
}
