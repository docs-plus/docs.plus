{
  "name": "@docs.plus/extension-placeholder",
  "version": "2.0.0",
  "description": "A performance-optimized Tiptap placeholder extension using O(1) cursor-based decoration",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "author": "Hossein Marzban",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=24.11.0"
  },
  "homepage": "https://github.com/docs-plus/docs.plus/tree/main/extensions/extension-placeholder#readme",
  "bugs": {
    "url": "https://github.com/docs-plus/docs.plus/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/docs-plus/docs.plus",
    "directory": "extensions/extension-placeholder"
  },
  "scripts": {
    "build": "NODE_ENV=production bunx tsup",
    "dev": "bunx tsup --watch",
    "playground": "bun --hot docs-playground --entry ./test/playground/main.ts --port 5177",
    "docs:screenshots": "bun run build && bunx start-server-and-test playground http://127.0.0.1:5177 'bunx cypress run --config specPattern=cypress/docs/**/*.cy.ts'",
    "pretest": "bun run build",
    "test": "bunx start-server-and-test playground http://127.0.0.1:5177 cypress:run",
    "test:e2e": "bunx start-server-and-test playground http://127.0.0.1:5177 cypress:run",
    "test:e2e:watch": "bunx start-server-and-test playground http://127.0.0.1:5177 cypress:open",
    "cypress:run": "bunx cypress run",
    "cypress:open": "bunx cypress open",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "prepack": "bunx release-prepack",
    "prepublishOnly": "bunx release-preflight"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "tiptap",
    "tiptap extension",
    "placeholder",
    "prosemirror",
    "docs.plus"
  ],
  "peerDependencies": {
    "@tiptap/core": "catalog:",
    "@tiptap/pm": "catalog:"
  },
  "devDependencies": {
    "@docs.plus/playground": "workspace:*",
    "@docs.plus/release-tooling": "workspace:*",
    "@tiptap/core": "catalog:",
    "@tiptap/pm": "catalog:",
    "@tiptap/starter-kit": "catalog:",
    "cypress": "catalog:",
    "cypress-real-events": "catalog:",
    "eslint": "catalog:",
    "start-server-and-test": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:"
  }
}
