{
  "name": "@docs.plus/extension-inline-code",
  "version": "2.0.0",
  "description": "A Tiptap extension for inline code formatting",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "author": "Hossein Marzban",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "homepage": "https://github.com/docs-plus/docs.plus/tree/main/extensions/extension-inline-code#readme",
  "bugs": {
    "url": "https://github.com/docs-plus/docs.plus/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/docs-plus/docs.plus",
    "directory": "extensions/extension-inline-code"
  },
  "scripts": {
    "build": "NODE_ENV=production bunx tsup",
    "dev": "bunx tsup --watch",
    "playground": "bun --hot docs-playground --entry ./test/playground/main.ts --port 5176",
    "pretest": "bun run build",
    "test": "bunx start-server-and-test playground http://127.0.0.1:5176 cypress:run",
    "test:e2e": "bunx start-server-and-test playground http://127.0.0.1:5176 cypress:run",
    "test:e2e:watch": "bunx start-server-and-test playground http://127.0.0.1:5176 cypress:open",
    "cypress:run": "bunx cypress run",
    "cypress:open": "bunx cypress open",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "prepack": "release-prepack",
    "prepublishOnly": "release-preflight"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "tiptap",
    "tiptap extension",
    "inline code",
    "code",
    "text editor",
    "rich text",
    "prosemirror",
    "docs.plus"
  ],
  "peerDependencies": {
    "@tiptap/core": "catalog:",
    "@tiptap/pm": "catalog:"
  },
  "devDependencies": {
    "@docs.plus/playground": "workspace:*",
    "@docs.plus/release-tooling": "workspace:*",
    "@tiptap/core": "catalog:",
    "@tiptap/pm": "catalog:",
    "@tiptap/starter-kit": "catalog:",
    "cypress": "catalog:",
    "cypress-real-events": "catalog:",
    "eslint": "catalog:",
    "start-server-and-test": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:"
  }
}
