{
  "name": "@docs.plus/extension-indent",
  "version": "0.2.0",
  "description": "A Tiptap extension for managing text indentation in documents",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "author": "Hossein Marzban",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/docs-plus/docs.plus/tree/main/extensions/extension-indent#readme",
  "bugs": {
    "url": "https://github.com/docs-plus/docs.plus/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/docs-plus/docs.plus",
    "directory": "extensions/extension-indent"
  },
  "scripts": {
    "build": "NODE_ENV=production bunx tsup",
    "dev": "bunx tsup --watch",
    "test": "jest --config jest.config.cjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepack": "release-prepack",
    "prepublishOnly": "release-preflight"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "tiptap",
    "tiptap extension",
    "indent",
    "outdent",
    "text editor",
    "rich text",
    "prosemirror",
    "docs.plus"
  ],
  "peerDependencies": {
    "@tiptap/core": "catalog:",
    "@tiptap/pm": "catalog:"
  },
  "devDependencies": {
    "@docs.plus/release-tooling": "workspace:*",
    "@tiptap/core": "catalog:",
    "@tiptap/pm": "catalog:",
    "@tiptap/starter-kit": "catalog:",
    "eslint": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:"
  }
}
