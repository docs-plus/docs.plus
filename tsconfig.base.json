{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "declaration": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": [],
    // TS6's dts toolchain injects a `baseUrl` it flags as TS5101 (baseUrl is removed in TS7).
    // Acknowledge the deprecation so the extension `.d.ts` builds emit; drop once baseUrl is gone repo-wide.
    "ignoreDeprecations": "5.0"
  }
}
