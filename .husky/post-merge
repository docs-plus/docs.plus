#!/bin/sh

REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null)
if [ -z "$REPO_ROOT" ]; then
    echo "❌ Could not resolve repository root. Post-merge hook aborted."
    exit 1
fi

HOOK_SCRIPT="$REPO_ROOT/scripts/hooks/post-merge.sh"
if [ ! -f "$HOOK_SCRIPT" ]; then
    echo "❌ Missing hook script: $HOOK_SCRIPT"
    exit 1
fi

exec sh "$HOOK_SCRIPT" "$@"

