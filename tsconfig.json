{
  "compilerOptions": {
    "target": "ES2019",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "importHelpers": true,
    "allowSyntheticDefaultImports": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "sourceMap": true,
    "baseUrl": "./",
    "paths": {
      "@docs.plus/*": [
        "packages/*/dist",
        "packages/*/src",
        "apps/*/dist",
        "apps/*/src",
        "extensions/*/dist",
        "extensions/*/src"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "apps/**/*.ts",
    "apps/**/*.tsx",
    "extensions/**/*.ts",
    "extensions/**/*.tsx"
  ],
  "exclude": ["node_modules", "apps/webapp"]
}
