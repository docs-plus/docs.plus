{
  "name": "@docs.plus/eslint-config",
  "version": "1.0.0",
  "private": true,
  "description": "Shared ESLint configuration for docs.plus monorepo",
  "main": "index.js",
  "exports": {
    ".": {
      "require": "./index.js",
      "import": "./index.js"
    },
    "./next": {
      "require": "./next.js",
      "import": "./next.js"
    },
    "./library": {
      "require": "./library.js",
      "import": "./library.js"
    }
  },
  "files": [
    "index.js",
    "next.js",
    "library.js"
  ],
  "peerDependencies": {
    "eslint": "catalog:"
  },
  "dependencies": {
    "@eslint/js": "catalog:",
    "@typescript-eslint/eslint-plugin": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-prettier": "catalog:",
    "eslint-plugin-react": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "globals": "catalog:"
  }
}
