{
  "name": "@docs.plus/eslint-config",
  "version": "1.0.0",
  "private": true,
  "description": "Shared ESLint configuration for docs.plus monorepo",
  "main": "index.js",
  "exports": {
    ".": {
      "require": "./index.js",
      "import": "./index.js"
    },
    "./next": {
      "require": "./next.js",
      "import": "./next.js"
    },
    "./library": {
      "require": "./library.js",
      "import": "./library.js"
    }
  },
  "files": [
    "index.js",
    "next.js",
    "library.js"
  ],
  "peerDependencies": {
    "eslint": "^9.39.3"
  },
  "dependencies": {
    "@eslint/js": "^9.39.3",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0"
  }
}
