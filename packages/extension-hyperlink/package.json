{
  "name": "@docs.plus/extension-hyperlink",
  "version": "2.0.0",
  "description": "Tiptap extension for hyperlinks with built-in popovers, auto-linking, and 50+ URL scheme support",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "author": "Hossein Marzban",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/docs-plus/docs.plus/tree/main/packages/extension-hyperlink#readme",
  "bugs": {
    "url": "https://github.com/docs-plus/docs.plus/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/docs-plus/docs.plus",
    "directory": "packages/extension-hyperlink"
  },
  "scripts": {
    "build": "NODE_ENV=production bunx tsup",
    "build:dev": "bunx tsup",
    "dev": "bunx tsup --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "playground": "bun --hot ./test/playground/server.ts",
    "test:unit": "bun test src",
    "test:unit:watch": "bun test --watch src",
    "pretest": "bun run build",
    "test": "bun run test:unit && bunx start-server-and-test playground http://127.0.0.1:5173 cy:run",
    "test:e2e": "bunx start-server-and-test playground http://127.0.0.1:5173 cy:run",
    "test:open": "bunx start-server-and-test playground http://127.0.0.1:5173 cy:open",
    "cy:run": "bunx cypress run",
    "cy:open": "bunx cypress open",
    "docs:screenshots": "bun run build && bunx start-server-and-test playground http://127.0.0.1:5173 'bunx cypress run --config specPattern=cypress/docs/**/*.cy.ts'",
    "prepack": "bun run scripts/prepack.ts",
    "prepublishOnly": "bun run scripts/preflight.ts"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "tiptap",
    "tiptap extension",
    "hyperlink",
    "link",
    "autolink",
    "rich-text-editor",
    "floating-ui",
    "url-validation",
    "prosemirror",
    "docs.plus"
  ],
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "linkifyjs": "^4.3.2"
  },
  "peerDependencies": {
    "@tiptap/core": "catalog:",
    "@tiptap/pm": "catalog:"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@tiptap/core": "catalog:",
    "@tiptap/pm": "catalog:",
    "@tiptap/starter-kit": "catalog:",
    "@types/node": "catalog:",
    "@typescript-eslint/eslint-plugin": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "bun-types": "latest",
    "cypress": "catalog:",
    "cypress-real-events": "catalog:",
    "eslint": "catalog:",
    "globals": "catalog:",
    "start-server-and-test": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:"
  }
}
