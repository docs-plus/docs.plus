{
  "name": "@docs.plus/playground",
  "version": "0.0.0",
  "private": true,
  "description": "Internal clean-room Cypress harness for @docs.plus/extension-* (docs-playground + setupPlayground). Never published.",
  "type": "module",
  "bin": {
    "docs-playground": "./src/launch.ts"
  },
  "exports": {
    "./setup": "./src/setup.ts",
    "./tsconfig.json": "./tsconfig.json",
    "./cypress/flattenReadmeScreenshots": "./cypress/flattenReadmeScreenshots.ts",
    "./cypress/readmeGallery": "./cypress/readmeGallery.ts",
    "./cypress/markdownCommands": "./cypress/markdownCommands.ts",
    "./cypress/tsconfig.json": "./cypress/tsconfig.json",
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "cypress"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@types/node": "catalog:",
    "@typescript-eslint/eslint-plugin": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "bun-types": "catalog:",
    "eslint": "catalog:",
    "globals": "catalog:",
    "typescript": "catalog:"
  }
}
