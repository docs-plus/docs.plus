{
  "name": "@docs.plus/extension-hypermultimedia",
  "version": "1.4.0",
  "description": "Insert embeded multimedia components for docs.plus",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "author": "Hossein Marzban",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/docs-plus/docs.plus/tree/main/packages/extension-hypermultimedia#readme",
  "bugs": {
    "url": "https://github.com/docs-plus/docs.plus/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/docs-plus/docs.plus",
    "directory": "packages/extension-hypermultimedia"
  },
  "scripts": {
    "build": "NODE_ENV=production bunx tsup",
    "dev": "bunx tsup --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepack": "release-prepack",
    "prepublishOnly": "release-preflight"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "tiptap",
    "tiptap extension",
    "insert Media",
    "multimedia",
    "youtube",
    "vimeo",
    "soundcloud",
    "twitter",
    "prosemirror",
    "docs.plus"
  ],
  "peerDependencies": {
    "@tiptap/core": "catalog:",
    "@tiptap/pm": "catalog:"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "tippy.js": "^6.3.7"
  },
  "devDependencies": {
    "@docs.plus/release-tooling": "workspace:*",
    "@tiptap/core": "catalog:",
    "@tiptap/pm": "catalog:",
    "@eslint/js": "catalog:",
    "@types/minimatch": "catalog:",
    "@typescript-eslint/eslint-plugin": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "eslint": "catalog:",
    "globals": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:"
  }
}
