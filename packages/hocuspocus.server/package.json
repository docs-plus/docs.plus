{
  "name": "@docs.plus/hocuspocus",
  "version": "2.0.0-beta.103",
  "private": true,
  "description": "Hocuspocus is a suite of tools to bring collaboration to your application. It's based on Y.js (by Kevin Jahns), which is amazing to sync and merge changes from clients in real-time. But you can also use it to build offline-first apps, and sync changes later. We'll make sure to resolve conflicts and keep everything in sync, always.",
  "main": "src/index.ts",
  "scripts": {
    "dev:rest": "NODE_ENV=development bun --env-file ../../.env.local --watch src/index.ts",
    "dev:hocuspocus.server": "NODE_ENV=development bun --env-file ../../.env.local --watch src/hocuspocus.server.ts",
    "dev:hocuspocus.worker": "NODE_ENV=development bun --env-file ../../.env.local --watch src/hocuspocus.worker.ts",
    "start:rest": "NODE_ENV=production bun scripts/start-production.ts",
    "start:hocuspocus.server": "NODE_ENV=production bun src/hocuspocus.server.ts",
    "start:hocuspocus.worker": "NODE_ENV=production bun src/hocuspocus.worker.ts",
    "build": "bun build src/index.ts src/hocuspocus.server.ts src/hocuspocus.worker.ts --outdir=dist --target=bun",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "prisma:init:migrations": "bun --env-file ../../.env.local prisma migrate dev --name init",
    "prisma:migrate:dev": "bun --env-file ../../.env.local prisma migrate dev",
    "prisma:generate": "bun --env-file ../../.env.local prisma generate --schema=./prisma/schema.prisma",
    "fix:migration": "bun scripts/fix-migration.ts",
    "update:packages": "bunx npm-check-updates -u"
  },
  "keywords": [],
  "author": "Hossein Marzban",
  "type": "module",
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^6.4.23",
    "@types/pg": "^8.18.0",
    "@types/web-push": "^3.6.4",
    "bun-types": "latest",
    "prisma": "^6.19.2"
  },
  "dependencies": {
    "@docs.plus/email-templates": "workspace:*",
    "@hocuspocus/extension-database": "^3.4.4",
    "@hocuspocus/extension-logger": "^3.4.4",
    "@hocuspocus/extension-redis": "^3.4.4",
    "@hocuspocus/extension-throttle": "^3.4.4",
    "@hocuspocus/server": "^3.4.4",
    "@hocuspocus/transformer": "^3.4.4",
    "@hono/zod-validator": "^0.7.6",
    "@prisma/adapter-pg": "^6.19.2",
    "@prisma/client": "^6.19.2",
    "@supabase/supabase-js": "^2.98.0",
    "@tiptap/core": "^3.20.0",
    "@tiptap/extension-document": "^3.20.0",
    "@tiptap/extension-paragraph": "^3.20.0",
    "@tiptap/extension-text": "^3.20.0",
    "@tiptap/html": "^3.20.0",
    "@tiptap/pm": "^3.20.0",
    "bullmq": "^5.70.1",
    "hono": "^4.12.3",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "mime": "^4.1.0",
    "nodemailer": "^6.10.1",
    "pg": "^8.19.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "rate-limiter-flexible": "^8.3.0",
    "short-unique-id": "^5.3.2",
    "slugify": "^1.6.6",
    "yjs": "^13.6.29",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  }
}
