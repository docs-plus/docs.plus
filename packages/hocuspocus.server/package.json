{
  "name": "@docs.plus/hocuspocus",
  "version": "2.0.0-beta.103",
  "private": true,
  "description": "Hocuspocus is a suite of tools to bring collaboration to your application. It's based on Y.js (by Kevin Jahns), which is amazing to sync and merge changes from clients in real-time. But you can also use it to build offline-first apps, and sync changes later. We'll make sure to resolve conflicts and keep everything in sync, always.",
  "main": "src/index.ts",
  "scripts": {
    "dev:rest": "NODE_ENV=development bun --env-file ../../.env.local --watch src/index.ts",
    "dev:hocuspocus.server": "NODE_ENV=development bun --env-file ../../.env.local --watch src/hocuspocus.server.ts",
    "dev:hocuspocus.worker": "NODE_ENV=development bun --env-file ../../.env.local --watch src/hocuspocus.worker.ts",
    "start:rest": "NODE_ENV=production bun scripts/start-production.ts",
    "start:hocuspocus.server": "NODE_ENV=production bun src/hocuspocus.server.ts",
    "start:hocuspocus.worker": "NODE_ENV=production bun src/hocuspocus.worker.ts",
    "build": "bun build src/index.ts src/hocuspocus.server.ts src/hocuspocus.worker.ts --outdir=dist --target=bun",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "test:link-metadata": "bun test src/modules/link-metadata",
    "test:link-metadata:watch": "bun test --watch src/modules/link-metadata",
    "test:link-metadata:coverage": "bun test --coverage src/modules/link-metadata",
    "prisma:init:migrations": "bun --env-file ../../.env.local prisma migrate dev --name init",
    "prisma:migrate:dev": "bun --env-file ../../.env.local prisma migrate dev",
    "prisma:generate": "bun --env-file ../../.env.local prisma generate --schema=./prisma/schema.prisma",
    "fix:migration": "bun scripts/fix-migration.ts",
    "migrate:nested-to-flat": "bun --env-file ../../.env.local src/scripts/migrate-nested-to-flat.ts",
    "migrate:nested-to-flat:dry": "bun --env-file ../../.env.local src/scripts/migrate-nested-to-flat.ts --dry-run"
  },
  "keywords": [],
  "author": "Hossein Marzban",
  "type": "module",
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^7.0.5",
    "@types/pg": "^8.20.0",
    "@types/web-push": "^3.6.4",
    "bun-types": "latest",
    "prisma": "^6.19.3"
  },
  "dependencies": {
    "@docs.plus/email-templates": "workspace:*",
    "@docs.plus/extension-hypermultimedia": "workspace:*",
    "@docs.plus/extension-inline-code": "workspace:*",
    "@hocuspocus/extension-database": "catalog:",
    "@hocuspocus/extension-logger": "catalog:",
    "@hocuspocus/extension-redis": "catalog:",
    "@hocuspocus/extension-throttle": "catalog:",
    "@hocuspocus/server": "catalog:",
    "@hocuspocus/transformer": "catalog:",
    "@hono/zod-validator": "^0.7.6",
    "@prisma/adapter-pg": "^6.19.3",
    "@prisma/client": "^6.19.3",
    "@supabase/supabase-js": "catalog:",
    "@tiptap/core": "catalog:",
    "@tiptap/extension-document": "catalog:",
    "@tiptap/extension-heading": "catalog:",
    "@tiptap/extension-list": "catalog:",
    "@tiptap/extension-paragraph": "catalog:",
    "@tiptap/extension-subscript": "catalog:",
    "@tiptap/extension-superscript": "catalog:",
    "@tiptap/extension-table": "catalog:",
    "@tiptap/extension-text": "catalog:",
    "@tiptap/html": "catalog:",
    "@tiptap/pm": "catalog:",
    "@tiptap/starter-kit": "catalog:",
    "bullmq": "^5.73.2",
    "hono": "^4.12.12",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "metascraper": "^5.46.0",
    "metascraper-author": "^5.46.0",
    "metascraper-date": "^5.46.0",
    "metascraper-description": "^5.46.0",
    "metascraper-image": "^5.46.0",
    "metascraper-lang": "^5.46.0",
    "metascraper-logo": "^5.46.0",
    "metascraper-publisher": "^5.46.0",
    "metascraper-title": "^5.46.0",
    "metascraper-url": "^5.46.0",
    "mime": "^4.1.0",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "rate-limiter-flexible": "^8.3.0",
    "short-unique-id": "^5.3.2",
    "slugify": "^1.6.9",
    "web-push": "^3.6.7",
    "yjs": "catalog:",
    "zod": "^4.3.6"
  }
}
