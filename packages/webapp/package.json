{
  "name": "@docs.plus/webapp",
  "version": "2.0.0-beta.103",
  "private": true,
  "browserslist": "> 1%",
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:local": "dotenv -e ../../.env.local -- next dev --turbopack",
    "dev:coverage": "CYPRESS_COVERAGE=true COVERAGE=true next dev -p 3001",
    "build": "dotenv -e ../../.env.production -- next build",
    "build:local": "dotenv -e ../../.env.local -- next build",
    "build:ci": "next build",
    "start": "node .next/standalone/packages/webapp/server.js",
    "start:local": "dotenv -e ../../.env.local -- node .next/standalone/packages/webapp/server.js",
    "start:prod": "PORT=3001 bun .next/standalone/packages/webapp/server.js",
    "start:stage": "PORT=3000 bun .next/standalone/packages/webapp/server.js",
    "docker:build": "bash scripts/build-local.sh",
    "docker:up": "make up",
    "docker:down": "make down",
    "docker:logs": "make logs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --coverage --passWithNoTests",
    "cypress:open": "bunx cypress open",
    "cypress:run": "bunx cypress run",
    "cypress:run:coverage": "CYPRESS_COVERAGE=true COVERAGE=true bunx cypress run",
    "coverage:clean": "rm -rf .nyc_output coverage",
    "coverage:report": "nyc report --temp-dir .nyc_output --report-dir coverage --reporter=text-summary --reporter=lcov --reporter=html",
    "coverage:check:global": "nyc check-coverage --temp-dir .nyc_output --lines ${COV_GLOBAL_LINES:-50} --statements ${COV_GLOBAL_STATEMENTS:-45} --functions ${COV_GLOBAL_FUNCTIONS:-40} --branches ${COV_GLOBAL_BRANCHES:-45}",
    "coverage:check:editor-core": "nyc check-coverage --temp-dir .nyc_output --include \"src/components/TipTap/**\" --lines ${COV_EDITOR_LINES:-60} --statements ${COV_EDITOR_STATEMENTS:-55} --functions ${COV_EDITOR_FUNCTIONS:-50} --branches ${COV_EDITOR_BRANCHES:-55}",
    "coverage:enforce": "bun run coverage:report && bun run coverage:check:global && bun run coverage:check:editor-core",
    "find-unused": "bunx next-unused"
  },
