    "@tiptap/markdown": "^3.22.3",
    "@tiptap/pm": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "@types/minimatch": "^6.0.0",
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "bun-types": "^1.3.13",
    "cypress": "^15.13.1",
    "cypress-real-events": "^1.15.0",
    "eslint": "^9.39.4",
