{
  "name": "docs.plus",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "prettier": "./.prettierrc.json",
  "scripts": {
    "prepare": "husky",
    "postinstall": "bun run --filter @docs.plus/hocuspocus prisma:generate || true",
    "doctor": "bun scripts/doctor.ts",
    "release:family": "bun scripts/release-family.ts",
    "start:webapp": "cd packages/webapp && bun run start",
    "dev": "bun --filter @docs.plus/webapp run dev",
    "dev:local": "make dev-local",
    "dev:backend": "make dev-backend",
    "dev:webapp": "make dev-webapp",
    "dev:rest": "make dev-rest",
    "dev:ws": "make dev-ws",
    "dev:worker": "make dev-worker",
    "dev:admin": "bun --filter @docs.plus/admin-dashboard run dev",
    "dev:admin:local": "bun --filter @docs.plus/admin-dashboard run dev:local",
    "build:admin": "bun --filter @docs.plus/admin-dashboard run build",
    "build": "bun run --filter '*' build",
    "check": "bun run lint && bun run format && bun run styles && bun run typecheck",
    "check:fix": "bun run lint:fix && bun run styles:fix && bun run format:fix",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "styles": "stylelint 'packages/**/*.{css,scss}' --allow-empty-input",
    "styles:fix": "stylelint 'packages/**/*.{css,scss}' --fix --allow-empty-input",
    "lint:staged": "lint-staged",
    "typecheck": "bun run typecheck:webapp && bun run typecheck:admin && bun run typecheck:backend",
    "typecheck:webapp": "cd packages/webapp && bun run tsc --noEmit",
    "typecheck:admin": "cd packages/admin-dashboard && bun run tsc --noEmit",
    "typecheck:backend": "cd packages/hocuspocus.server && bun run tsc --noEmit",
    "update:all-packages": "sh ./scripts/update-packages.sh",
    "pre-push": "bun scripts/pre-push.ts",
    "test:all": "bash ./scripts/run-tests.sh",
    "test:unit": "bash ./scripts/run-tests.sh --unit",
    "test:e2e": "bash ./scripts/run-tests.sh --e2e",
    "test:e2e:2": "CYPRESS_PARALLEL=2 bash ./scripts/run-tests.sh --e2e",
    "test:e2e:4": "CYPRESS_PARALLEL=4 bash ./scripts/run-tests.sh --e2e",
    "test:e2e:8": "CYPRESS_PARALLEL=8 bash ./scripts/run-tests.sh --e2e",
    "cypress:open": "bunx cypress open",
    "cypress:run": "bunx cypress run"
  },
  "engines": {
    "node": ">=24.11.0",
    "bun": ">=1.3.7"
  },
  "dependencies": {
    "bson": "^7.2.0",
    "lodash": "^4.18.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-proposal-nullish-coalescing-operator": "^7.18.6",
    "@babel/plugin-proposal-optional-chaining": "^7.21.0",
    "@babel/plugin-syntax-typescript": "^7.28.6",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/minimatch": "^6.0.0",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "babel-jest": "^30.3.0",
    "babel-loader": "^10.1.1",
    "babel-plugin-module-resolver": "^5.0.3",
    "bun-types": "^1.3.11",
    "conventional-changelog-cli": "^5.0.0",
    "eslint": "^10.2.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-html": "^8.1.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-vue": "^10.8.0",
    "fs-extra": "^11.3.4",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "lint-staged": "^16.4.0",
    "minimist": "^1.2.8",
    "next-transpile-modules": "^10.0.1",
    "prettier": "catalog:",
    "prettier-plugin-tailwindcss": "catalog:",
    "sass": "^1.99.0",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "^8.1.1",
    "ts-loader": "9.5.7",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "webpack": "^5.106.0"
  },
  "catalog": {
    "@eslint/js": "^9.39.4",
    "@hocuspocus/extension-database": "^3.4.4",
    "@hocuspocus/extension-logger": "^3.4.4",
    "@hocuspocus/extension-redis": "^3.4.4",
    "@hocuspocus/extension-throttle": "^3.4.4",
    "@hocuspocus/provider": "^3.4.4",
    "@hocuspocus/server": "^3.4.4",
    "@hocuspocus/transformer": "^3.4.4",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.103.0",
    "supabase": "^2.88.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/react-query": "^5.100.5",
    "clsx": "^2.1.1",
    "daisyui": "^5.5.19",
    "date-fns": "^4.1.0",
    "dotenv-cli": "^11.0.0",
    "immer": "^11.1.4",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "y-indexeddb": "^9.0.12",
    "yjs": "^13.6.30",
    "zustand": "^5.0.12",
    "@tiptap/core": "^3.22.3",
    "@tiptap/extension-blockquote": "^3.22.3",
    "@tiptap/extension-bold": "^3.22.3",
    "@tiptap/extension-code-block": "^3.22.3",
    "@tiptap/extension-code-block-lowlight": "^3.22.3",
    "@tiptap/extension-collaboration": "^3.22.3",
    "@tiptap/extension-collaboration-caret": "^3.22.3",
    "@tiptap/extension-document": "^3.22.3",
    "@tiptap/extension-hard-break": "^3.22.3",
    "@tiptap/extension-heading": "^3.22.3",
    "@tiptap/extension-highlight": "^3.22.3",
    "@tiptap/extension-image": "^3.22.3",
    "@tiptap/extension-italic": "^3.22.3",
    "@tiptap/extension-link": "^3.22.3",
    "@tiptap/extension-list": "^3.22.3",
    "@tiptap/extension-mention": "^3.22.3",
    "@tiptap/extension-paragraph": "^3.22.3",
    "@tiptap/extension-strike": "^3.22.3",
    "@tiptap/extension-subscript": "^3.22.3",
    "@tiptap/extension-superscript": "^3.22.3",
    "@tiptap/extension-table": "^3.22.3",
    "@tiptap/extension-text": "^3.22.3",
    "@tiptap/extension-text-align": "^3.22.3",
    "@tiptap/extension-typography": "^3.22.3",
    "@tiptap/extension-underline": "^3.22.3",
    "@tiptap/extension-unique-id": "^3.22.3",
    "@tiptap/extensions": "^3.22.3",
    "@tiptap/html": "^3.22.3",
    "@tiptap/markdown": "^3.22.3",
    "@tiptap/pm": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "@types/minimatch": "^6.0.0",
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "cypress": "^15.13.1",
    "cypress-real-events": "^1.15.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.4.0",
    "start-server-and-test": "^2.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
