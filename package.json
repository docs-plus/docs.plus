{
  "name": "docs.plus",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "extensions/*",
    "packages/*"
  ],
  "overrides": {
    "@metascraper/helpers": "5.50.6"
  },
  "prettier": "./.prettierrc.json",
  "scripts": {
    "prepare": "husky",
    "postinstall": "bun --filter @docs.plus/hocuspocus prisma:generate || true",
    "dev": "bun --filter @docs.plus/webapp dev",
    "dev:admin": "bun --filter @docs.plus/admin-dashboard dev",
    "build": "bun run --filter '*' build",
    "start": "bun --filter @docs.plus/webapp start",
    "check": "bun run lint && bun run lint:styles && bun run format && bun run typecheck",
    "check:fix": "bun run lint:fix && bun run lint:styles:fix && bun run format:fix",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:styles": "stylelint '{apps,extensions,packages}/**/*.{css,scss}' --allow-empty-input",
    "lint:styles:fix": "stylelint '{apps,extensions,packages}/**/*.{css,scss}' --fix --allow-empty-input",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "bun run --filter '*' typecheck",
    "lint-staged": "lint-staged",
    "test": "bash ./scripts/run-tests.sh",
    "test:unit": "bash ./scripts/run-tests.sh --unit",
    "test:e2e": "bash ./scripts/run-tests.sh --e2e",
    "doctor": "bun scripts/doctor.ts",
    "release:family": "bun scripts/release-family.ts",
    "update": "bash ./scripts/update-packages.sh",
    "pre-push": "bun scripts/pre-push.ts"
  },
  "engines": {
    "node": ">=24.11.0",
    "bun": ">=1.3.7"
  },
  "dependencies": {
    "bson": "^7.3.0",
    "lodash": "^4.18.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/plugin-proposal-nullish-coalescing-operator": "^7.18.6",
    "@babel/plugin-proposal-optional-chaining": "^7.21.0",
    "@babel/plugin-syntax-typescript": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/minimatch": "^6.0.0",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "babel-jest": "^30.4.1",
    "babel-loader": "^10.1.1",
    "babel-plugin-module-resolver": "^5.0.3",
    "bun-types": "^1.3.14",
    "conventional-changelog-cli": "^5.0.0",
    "eslint": "^10.5.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-html": "^8.1.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-vue": "^10.9.2",
    "fs-extra": "^11.3.5",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "lint-staged": "^17.0.7",
    "minimist": "^1.2.8",
    "next-transpile-modules": "^10.0.1",
    "npm-check-updates": "^22.2.3",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "sass": "^1.101.0",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "^8.1.1",
    "ts-loader": "9.6.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "webpack": "^5.107.2"
